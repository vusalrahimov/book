graph LR
    subgraph Driving["🔵 Driving Side (Left) — Initiates Action"]
        REST["REST Controller\nHTTP / JSON"]
        GRPC["gRPC Server\nProtobuf"]
        CLI["CLI Runner\nSpring Boot"]
        MQ_IN["Kafka Consumer\nMessage Listener"]
    end

    subgraph Hexagon["⬡ Application Core (Domain)"]
        direction TB
        PORT_IN["«Port»\nDriving Ports\n(Use Case Interfaces)"]
        DOMAIN["Domain Model\nAggregates · Entities\nValue Objects · Events\nDomain Services"]
        PORT_OUT["«Port»\nDriven Ports\n(Repository Interfaces)"]
    end

    subgraph Driven["🟢 Driven Side (Right) — Receives Calls"]
        JPA["JPA Adapter\nPostgreSQL"]
        REDIS_OUT["Redis Adapter\nCache / Lock"]
        KAFKA_OUT["Kafka Producer\nEvent Publisher"]
        HTTP_OUT["HTTP Client\nExternal Service"]
        S3["S3 Adapter\nFile Storage"]
    end

    REST -->|PlaceOrderCommand| PORT_IN
    GRPC -->|GetOrderQuery| PORT_IN
    CLI -->|CancelOrderCommand| PORT_IN
    MQ_IN -->|PaymentConfirmedEvent| PORT_IN

    PORT_IN --> DOMAIN
    DOMAIN --> PORT_OUT

    PORT_OUT -->|save/findById| JPA
    PORT_OUT -->|get/put/evict| REDIS_OUT
    PORT_OUT -->|publishEvent| KAFKA_OUT
    PORT_OUT -->|callExternalAPI| HTTP_OUT
    PORT_OUT -->|uploadFile| S3

    style Hexagon fill:#e3f2fd,stroke:#1565c0,stroke-width:3px
    style Driving fill:#fff3e0,stroke:#e65100
    style Driven fill:#e8f5e9,stroke:#2e7d32
    style DOMAIN fill:#bbdefb,stroke:#1565c0
    style PORT_IN fill:#e1bee7,stroke:#6a1b9a
    style PORT_OUT fill:#e1bee7,stroke:#6a1b9a
